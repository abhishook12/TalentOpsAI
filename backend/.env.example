# ============================================================
# TalentOpsAI Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in values.
# NEVER commit .env to git.
#
# IMPORTANT: Your .env should NEVER point to the production
# database unless you are explicitly running a production
# deployment. Default to localhost or staging.
# ============================================================

# --- DATABASE ---
# Local development (default safe fallback):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talentops

# Preferred production database (Supabase):
# SUPABASE_DATABASE_URL=postgresql://postgres:<password>@<project>.pooler.supabase.com:5432/postgres

# Staging (Neon staging branch — get from Neon Console):
# DATABASE_URL=postgresql://neondb_owner:<password>@<staging-endpoint>.neon.tech/neondb?sslmode=require

# Production (ONLY set on your deployment platform, NEVER locally):
# DATABASE_URL=postgresql://neondb_owner:<password>@<prod-endpoint>.neon.tech/neondb?sslmode=require

# --- AUTH ---
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me
# APP_PASSWORD defaults to ADMIN_PASSWORD if not set

# --- ENVIRONMENT ---
# development | staging | production
ENV=development

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- STARTUP ---
# Set to true to auto-create tables on boot (safe for dev/staging, use carefully in production)
RUN_STARTUP_MIGRATIONS=true

# --- ADMIN ACCESS ---
# Set to true to skip admin auth checks (dev/staging only, NEVER in production)
FREE_ADMIN_MODE=true
